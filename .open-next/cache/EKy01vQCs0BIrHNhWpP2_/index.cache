sed min-h-screen flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><nav class=\"border-b border-[var(--border)] bg-[var(--background)]/80 backdrop-blur-sm sticky top-0 z-50\"><div class=\"max-w-5xl mx-auto px-6 h-16 flex items-center justify-between\"><a class=\"text-xl font-bold tracking-tight\" href=\"/\">paysdoc<span class=\"text-[var(--accent)]\">.nl</span></a><div class=\"flex items-center gap-6\"><a class=\"text-sm transition-colors text-[var(--accent)] font-medium\" href=\"/\">Home</a><a class=\"text-sm transition-colors text-[var(--muted)] hover:text-[var(--foreground)]\" href=\"/about\">About</a><a class=\"text-sm transition-colors text-[var(--muted)] hover:text-[var(--foreground)]\" href=\"/services\">Services</a><a class=\"text-sm transition-colors text-[var(--muted)] hover:text-[var(--foreground)]\" href=\"/contact\">Contact</a><a class=\"text-sm text-[var(--muted)] hover:text-[var(--foreground)] transition-colors\" href=\"/login\">Login</a></div></div></nav><main class=\"flex-1\"><div class=\"max-w-5xl mx-auto px-6\"><section class=\"py-24 text-center\"><h1 class=\"text-4xl sm:text-5xl font-bold tracking-tight mb-6\">AI-Powered Software Development</h1><p class=\"text-lg text-[var(--muted)] max-w-2xl mx-auto mb-10\">Autonomous development workflows that plan, build, test, review, and document — from GitHub issue to production-ready pull request.</p><div class=\"flex gap-4 justify-center\"><a class=\"px-6 py-3 bg-[var(--accent)] text-white rounded-lg font-medium hover:bg-[var(--accent-hover)] transition-colors\" href=\"/contact\">Book a Discovery Call</a><a class=\"px-6 py-3 border border-[var(--border)] rounded-lg font-medium hover:bg-[var(--card-bg)] transition-colors\" href=\"/services\">View Services</a></div></section><section class=\"pb-24\"><h2 class=\"text-2xl font-bold text-center mb-12\">What I Build</h2><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"p-6 rounded-xl border border-[var(--border)] bg-[var(--card-bg)] hover:border-[var(--accent)] transition-colors\"><div class=\"text-3xl mb-4\">🤖</div><h3 class=\"text-lg font-semibold mb-2\">AI Agent Orchestration</h3><p class=\"text-sm text-[var(--muted)]\">Multi-agent workflows that autonomously plan, implement, test, and review code changes.</p></div><div class=\"p-6 rounded-xl border border-[var(--border)] bg-[var(--card-bg)] hover:border-[var(--accent)] transition-colors\"><div class=\"text-3xl mb-4\">🔄</div><h3 class=\"text-lg font-semibold mb-2\">Full SDLC Automation</h3><p class=\"text-sm text-[var(--muted)]\">From issue creation to merged pull request — planning, building, testing, reviewing, and documenting.</p></div><div class=\"p-6 rounded-xl border border-[var(--border)] bg-[var(--card-bg)] hover:border-[var(--accent)] transition-colors\"><div class=\"text-3xl mb-4\">🛠</div><h3 class=\"text-lg font-semibold mb-2\">TypeScript &amp; Node.js</h3><p class=\"text-sm text-[var(--muted)]\">Production-grade TypeScript systems with strong typing, modular architecture, and comprehensive testing.</p></div><div class=\"p-6 rounded-xl border border-[var(--border)] bg-[var(--card-bg)] hover:border-[var(--accent)] transition-colors\"><div class=\"text-3xl mb-4\">🌐</div><h3 class=\"text-lg font-semibold mb-2\">GitHub Integration</h3><p class=\"text-sm text-[var(--muted)]\">Webhook-driven automation that responds to issues, comments, and PRs in real time.</p></div><div class=\"p-6 rounded-xl border border-[var(--border)] bg-[var(--card-bg)] hover:border-[var(--accent)] transition-colors\"><div class=\"text-3xl mb-4\">🧪</div><h3 class=\"text-lg font-semibold mb-2\">Automated Testing</h3><p class=\"text-sm text-[var(--muted)]\">Unit, integration, and E2E test suites with automatic failure resolution and retry logic.</p></div><div class=\"p-6 rounded-xl border border-[var(--border)] bg-[var(--card-bg)] hover:border-[var(--accent)] transition-colors\"><div class=\"text-3xl mb-4\">📋</div><h3 class=\"text-lg font-semibold mb-2\">Auto Documentation</h3><p class=\"text-sm text-[var(--muted)]\">AI-generated technical documentation, conditional docs, and change summaries with every release.</p></div></div></section></div><!--$--><!--/$--></main><footer class=\"border-t border-[var(--border)] mt-auto\"><div class=\"max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--muted)]\"><p>© <!-- -->2026<!-- --> paysdoc.nl. All rights reserved.</p><div class=\"flex gap-6\"><a class=\"hover:text-[var(--foreground)] transition-colors\" href=\"https://github.com/paysdoc\">GitHub</a><a class=\"hover:text-[var(--foreground)] transition-colors\" href=\"/contact\">Contact</a></div></div></footer><script src=\"/_next/static/chunks/5c75c4cc39fc4c35.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[30824,[\\\"/_next/static/chunks/c27cca5e600d97f5.js\\\"],\\\"default\\\"]\\n3:I[45678,[\\\"/_next/static/chunks/c27cca5e600d97f5.js\\\"],\\\"default\\\"]\\n4:I[39756,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n5:I[37457,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n6:I[22016,[\\\"/_next/static/chunks/c27cca5e600d97f5.js\\\"],\\\"\\\"]\\ne:I[68027,[],\\\"default\\\"]\\n:HL[\\\"/_next/static/chunks/883c7f1ab3ae01f9.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.dbea232f.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.853070df.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"b\\\":\\\"EKy01vQCs0BIrHNhWpP2_\\\",\\\"c\\\":[\\\"\\\",\\\"\\\"],\\\"q\\\":\\\"\\\",\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\"